# ============================================================================
# METRICON VAULT - ENVIRONMENT CONFIGURATION
# Copy this file to .env.local and fill in the values
# ============================================================================

# ============================================================================
# SUPABASE (Required)
# Get these from your Supabase project settings
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key (for relayer only - do NOT expose to frontend)
SUPABASE_SERVICE_KEY=your-service-role-key

# ============================================================================
# SOLANA (Required)
# ============================================================================

# RPC endpoint (use devnet for testing)
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
RPC_URL=https://api.devnet.solana.com

# Program ID (update after deployment)
NEXT_PUBLIC_PROGRAM_ID=MetrVau1tXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ============================================================================
# RELAYER (Required for relayer worker)
# ============================================================================

# Relayer private key (base58 encoded or JSON array)
# Generate with: solana-keygen new --outfile relayer-keypair.json
RELAYER_PRIVATE_KEY=your-relayer-private-key

# ============================================================================
# CONFIGURATION
# ============================================================================

# Fee in basis points (30 = 0.3%)
NEXT_PUBLIC_FEE_BPS=30

# Withdraw delay in minutes
NEXT_PUBLIC_WITHDRAW_DELAY_MINUTES=5

# Relayer poll interval in milliseconds
POLL_INTERVAL_MS=5000

# Max retry attempts for failed withdrawals
MAX_RETRIES=3

# Batch size for processing withdrawals
BATCH_SIZE=5
